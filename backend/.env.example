# ==============================================================================
# LeadMe Backend - Environment Variables
# ==============================================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 채운다.
# cp .env.example .env
# ==============================================================================

# --- Database (Supabase PostgreSQL) ---
# Transaction Mode (포트 6543) + pgbouncer 파라미터 필수 (Serverless 환경)
# 로컬 개발 시에는 로컬 PostgreSQL 사용 가능
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# --- JWT ---
# 생성: openssl rand -base64 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- OpenRouter AI ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- App ---
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PORT=3001

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
