# ==============================================================================
# LeadMe Frontend - Environment Variables
# ==============================================================================
# 이 파일을 .env 로 복사한 뒤 실제 값을 채운다.
# cp .env.example .env
# ==============================================================================

# Backend API base URL (trailing slash 없음)
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Google OAuth Client ID (Google Cloud Console에서 발급)
VITE_GOOGLE_CLIENT_ID=
