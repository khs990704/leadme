# ==============================================================================
# LeadMe - Root Environment Variables (Reference Only)
# ==============================================================================
# 이 파일은 전체 환경변수 참조용이다.
# 실제 설정은 frontend/.env 와 backend/.env 에서 각각 관리한다.
# 절대로 실제 값을 이 파일에 넣지 마라.
# ==============================================================================

# --- Backend ---
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PORT=3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_GOOGLE_CLIENT_ID=
